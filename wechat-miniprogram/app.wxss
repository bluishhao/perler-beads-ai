/* app.wxss */
@import './styles/reset.wxss';

.container {
  width: 100%;
  min-height: 100vh;
  background-color: #F3F4F6;
  padding: 20rpx;
  box-sizing: border-box;
}

.btn {
  display: inline-block;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  cursor: pointer;
}

.btn-primary {
  background-color: #6366F1;
  color: #FFFFFF;
}

.btn-secondary {
  background-color: #FFFFFF;
  color: #6366F1;
  border: 2rpx solid #6366F1;
}

.input {
  width: 100%;
  padding: 16rpx;
  border: 2rpx solid #E5E7EB;
  border-radius: 8rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

.card {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #4B5563;
  margin-bottom: 16rpx;
}

.text {
  font-size: 28rpx;
  color: #6B7280;
  line-height: 1.5;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #6B7280;
  margin-left: 12rpx;
}

.error {
  color: #EF4444;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.success {
  color: #10B981;
  font-size: 24rpx;
  margin-top: 8rpx;
}