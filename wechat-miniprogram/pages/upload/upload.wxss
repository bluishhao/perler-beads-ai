/* upload.wxss */
.upload-area {
  width: 100%;
  height: 400rpx;
  border: 2rpx dashed #E5E7EB;
  border-radius: 12rpx;
  margin: 20rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #F9FAFB;
  cursor: pointer;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.upload-icon {
  font-size: 80rpx;
}

.upload-text {
  font-size: 32rpx;
  color: #4B5563;
  font-weight: 600;
}

.upload-subtext {
  font-size: 24rpx;
  color: #9CA3AF;
}

.upload-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.action-buttons {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn {
  width: 100%;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary {
  background-color: #6366F1;
  color: #FFFFFF;
}

.btn-primary:disabled {
  background-color: #A5B4FC;
  color: #FFFFFF;
}

.btn-secondary {
  background-color: #FFFFFF;
  color: #6366F1;
  border: 2rpx solid #6366F1;
}