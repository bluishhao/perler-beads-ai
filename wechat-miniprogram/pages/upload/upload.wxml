<!-- upload.wxml -->
<view class="container">
  <view class="card">
    <text class="subtitle">上传图片</text>
    <text class="text">请选择一张图片，支持 JPG、PNG 格式</text>
  </view>

  <view class="upload-area" bindtap="chooseImage">
    <view wx:if="{{ !imageUrl }}" class="upload-placeholder">
      <text class="upload-icon">📷</text>
      <text class="upload-text">点击选择图片</text>
      <text class="upload-subtext">或从相册选择</text>
    </view>
    <image wx:else class="upload-image" src="{{ imageUrl }}" mode="aspectFit" />
  </view>

  <view class="action-buttons">
    <button class="btn btn-primary" bindtap="confirmUpload" disabled="{{ !imageUrl }}">下一步</button>
    <button class="btn btn-secondary" bindtap="navigateBack">返回</button>
  </view>
</view>