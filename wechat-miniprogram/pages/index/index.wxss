/* index.wxss */
.feature-list {
  margin-top: 20rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.feature-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  width: 48rpx;
  text-align: center;
}

.feature-text {
  font-size: 28rpx;
  color: #6B7280;
}

.action-buttons {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn {
  width: 100%;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary {
  background-color: #6366F1;
  color: #FFFFFF;
}

.btn-secondary {
  background-color: #FFFFFF;
  color: #6366F1;
  border: 2rpx solid #6366F1;
}