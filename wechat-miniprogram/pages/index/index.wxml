<!-- index.wxml -->
<view class="container">
  <view class="card">
    <text class="title">拼豆图纸生成工具</text>
    <text class="text">将图片转换为拼豆图纸，支持多种色号系统</text>
  </view>

  <view class="card">
    <text class="subtitle">功能介绍</text>
    <view class="feature-list">
      <view class="feature-item">
        <text class="feature-icon">📷</text>
        <text class="feature-text">图片上传与裁剪</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">🎨</text>
        <text class="feature-text">像素化处理</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">🖌️</text>
        <text class="feature-text">手动编辑</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">💾</text>
        <text class="feature-text">下载图纸</text>
      </view>
    </view>
  </view>

  <view class="action-buttons">
    <button class="btn btn-primary" bindtap="navigateToUpload">开始使用</button>
    <button class="btn btn-secondary" bindtap="navigateToAbout">了解更多</button>
  </view>
</view>