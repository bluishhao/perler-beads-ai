/* settings.wxss */
.setting-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #4B5563;
  margin-bottom: 12rpx;
}

.setting-control {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.setting-unit {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #6B7280;
}

.setting-hint {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.radio-group {
  margin-top: 8rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.radio-item radio {
  margin-right: 12rpx;
}

.action-buttons {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn {
  width: 100%;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary {
  background-color: #6366F1;
  color: #FFFFFF;
}

.btn-secondary {
  background-color: #FFFFFF;
  color: #6366F1;
  border: 2rpx solid #6366F1;
}