<!-- settings.wxml -->
<view class="container">
  <view class="card">
    <text class="subtitle">像素化设置</text>
    <text class="text">请调整以下参数，以获得最佳的拼豆图纸效果</text>
  </view>

  <view class="card">
    <text class="setting-label">格子数量</text>
    <view class="setting-control">
      <input class="input" type="number" value="{{ granularity }}" bindinput="onGranularityChange" placeholder="请输入格子数量" />
      <text class="setting-unit">个</text>
    </view>
    <text class="setting-hint">建议值：30-100</text>
  </view>

  <view class="card">
    <text class="setting-label">相似度阈值</text>
    <view class="setting-control">
      <input class="input" type="number" value="{{ similarity }}" bindinput="onSimilarityChange" placeholder="请输入相似度阈值" />
      <text class="setting-unit">%</text>
    </view>
    <text class="setting-hint">建议值：20-50</text>
  </view>

  <view class="card">
    <text class="setting-label">像素化模式</text>
    <view class="radio-group">
      <radio-group bindchange="onModeChange">
        <label class="radio-item">
          <radio value="dominant" checked="{{ mode === 'dominant' }}" />
          <text>卡通模式（主色）</text>
        </label>
        <label class="radio-item">
          <radio value="average" checked="{{ mode === 'average' }}" />
          <text>真实模式（平均色）</text>
        </label>
      </radio-group>
    </view>
  </view>

  <view class="action-buttons">
    <button class="btn btn-primary" bindtap="confirmSettings">下一步</button>
    <button class="btn btn-secondary" bindtap="navigateBack">返回</button>
  </view>
</view>