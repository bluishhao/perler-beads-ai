/* download.wxss */
.checkbox-group {
  margin-top: 8rpx;
}

.checkbox-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.checkbox-item checkbox {
  margin-right: 12rpx;
}

.setting-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #4B5563;
  margin-bottom: 12rpx;
}

.setting-control {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.setting-unit {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #6B7280;
}

.color-picker {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.color-option {
  width: 60rpx;
  height: 60rpx;
  border-radius: 8rpx;
  cursor: pointer;
  border: 2rpx solid #E5E7EB;
}

.action-buttons {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn {
  width: 100%;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary {
  background-color: #6366F1;
  color: #FFFFFF;
}

.btn-secondary {
  background-color: #FFFFFF;
  color: #6366F1;
  border: 2rpx solid #6366F1;
}

.hidden-canvas {
  width: 600rpx;
  height: 600rpx;
  position: absolute;
  left: -9999rpx;
  top: -9999rpx;
  opacity: 0;
}