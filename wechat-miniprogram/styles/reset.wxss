/* reset.wxss */
view, text, input, button, textarea, select, image, scroll-view, swiper, swiper-item, navigator, block, template {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  color: #1F2937;
  background-color: #F3F4F6;
}

input, button, textarea, select {
  font-family: inherit;
  font-size: inherit;
  line-height: inherit;
}

button {
  border: none;
  outline: none;
  background: none;
  cursor: pointer;
}

input {
  outline: none;
}

ul, ol {
  list-style: none;
}

a {
  text-decoration: none;
  color: inherit;
}

image {
  vertical-align: middle;
}